# SwissQuote AI — Environment Variables Template
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local — it is gitignored.
# On Vercel: add each variable via Dashboard → Settings → Environment Variables
#            or via CLI: npx vercel env add <NAME> production

# ─── Supabase ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# ─── AI: Primary — Google Gemini ─────────────────────────────────────────────
# Get key at: https://aistudio.google.com/apikey
# Free tier: 1,500 requests/day, 1M tokens/min
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-3.5-flash

# ─── AI: Fallback — OpenRouter (free tier) ───────────────────────────────────
# Get keys at: https://openrouter.ai/keys
# OPENROUTER_API_KEYS: comma-separated list, tried in order on failure
# OPENROUTER_MODEL: use "openrouter/free" for automatic free model selection
OPENROUTER_API_KEYS=sk-or-v1-key1,sk-or-v1-key2,sk-or-v1-key3
OPENROUTER_MODEL=openrouter/free

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=SwissQuote AI
NEXT_PUBLIC_DEFAULT_CANTON=Genève
NEXT_PUBLIC_DEFAULT_SUPPLIER=NSB
